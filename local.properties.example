## Copy values into local.properties on your own machine.
## Android does not usually use .env directly inside the app module.
## The common mobile-native equivalent is local.properties -> BuildConfig.

sdk.dir=C\:\\Users\\YOUR_USER\\AppData\\Local\\Android\\Sdk
DEFAULT_ETH_NETWORK=sepolia
INFURA_PROJECT_ID=your_infura_project_id
BSC_RPC_URL=https://your-bsc-rpc-url/
AVALANCHE_RPC_URL=https://your-avalanche-rpc-url/
POLYGON_RPC_URL=https://your-polygon-rpc-url/
ARBITRUM_RPC_URL=https://your-arbitrum-rpc-url/
OPTIMISM_RPC_URL=https://your-optimism-rpc-url/
BASE_RPC_URL=https://your-base-rpc-url/
FANTOM_RPC_URL=https://your-fantom-rpc-url/
ETHERSCAN_API_KEY=your_etherscan_api_key
MATS_TOKEN_ADDRESS=your_mats_token_address
MATS_SWAP_POOL_ADDRESS=your_swap_pool_address
IDRX_TOKEN_ADDRESS=your_idrx_token_address
IDRX_SWAP_POOL_ADDRESS=your_idrx_swap_pool_address
# Optional extra real swap routes. Each slot appears in the swap picker only when
# ADDRESS and POOL_ADDRESS are both filled.
SWAP_TOKEN_1_NAME=Example Token
SWAP_TOKEN_1_SYMBOL=EXT
SWAP_TOKEN_1_ADDRESS=your_extra_token_address
SWAP_TOKEN_1_POOL_ADDRESS=your_extra_swap_pool_address
SWAP_TOKEN_1_DECIMALS=18
SWAP_TOKEN_2_NAME=
SWAP_TOKEN_2_SYMBOL=
SWAP_TOKEN_2_ADDRESS=
SWAP_TOKEN_2_POOL_ADDRESS=
SWAP_TOKEN_2_DECIMALS=18
MIDTRANS_PAYMENT_URL=your_midtrans_snap_redirect_or_payment_link_url
# Emulator Android: http://10.0.2.2:8787/
# Device fisik: pakai IP laptop/VPS, contoh http://192.168.1.10:8787/
BUY_BACKEND_BASE_URL=http://10.0.2.2:8787/
