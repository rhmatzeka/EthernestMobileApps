<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget" />

    <style name="Widget.MatsWallet" />

    <style name="Widget.MatsWallet.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/mw_highlight</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">18dp</item>
        <item name="iconTint">@color/white</item>
    </style>

    <style name="Widget.MatsWallet.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/mw_divider</item>
        <item name="android:textColor">@color/mw_text_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="iconTint">@color/mw_text_primary</item>
    </style>

    <style name="Widget.MatsWallet.Button.Tonal" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/mw_surface_elevated</item>
        <item name="android:textColor">@color/mw_text_primary</item>
        <item name="cornerRadius">18dp</item>
    </style>

    <style name="Widget.MatsWallet.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/mw_bottom_nav</item>
    </style>

    <style name="Widget.MatsWallet.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/mw_surface</item>
        <item name="boxStrokeColor">@color/mw_highlight</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.MatsWallet.Medium</item>
        <item name="hintTextColor">@color/mw_text_secondary</item>
    </style>

    <style name="Widget.MatsWallet.PinSlot" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">38dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@drawable/bg_pin_slot_empty</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/mw_text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.MatsWallet.PinKey" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_gravity">fill</item>
        <item name="android:layout_margin">7dp</item>
        <item name="android:background">@drawable/bg_pin_key</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/mw_text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.MatsWallet.PinKey.Action" parent="Widget.MatsWallet.PinKey">
        <item name="android:background">@drawable/bg_pin_key_action</item>
        <item name="android:textColor">@color/mw_text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.MatsWallet.ExchangeRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:background">@drawable/bg_card_surface_elevated</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <style name="Widget.MatsWallet.ExchangeLogo">
        <item name="android:layout_width">34dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:background">@drawable/bg_receive_action</item>
        <item name="android:padding">5dp</item>
        <item name="android:scaleType">centerCrop</item>
    </style>

    <style name="Widget.MatsWallet.ExchangeName">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">14dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/mw_text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.MatsWallet.ExchangeArrow">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:src">@drawable/ic_chevron_right_24</item>
    </style>

    <style name="Widget.MatsWallet.PaymentMethodIcon">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/bg_payment_method_icon</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/mw_highlight</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.MatsWallet.BuyKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_gravity">fill</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/mw_text_primary</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ShapeAppearanceOverlay" />

    <style name="ShapeAppearanceOverlay.MatsWallet" parent="ShapeAppearanceOverlay" />

    <style name="ShapeAppearanceOverlay.MatsWallet.Medium" parent="ShapeAppearanceOverlay.MatsWallet">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>
</resources>
