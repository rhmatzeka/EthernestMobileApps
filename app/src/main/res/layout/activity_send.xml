<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sendRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mw_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="28dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_icon_btn"
                android:contentDescription="@string/back_action"
                android:padding="10dp"
                android:src="@drawable/ic_back_24"
                android:tint="@color/mw_text_primary" />

            <TextView
                android:id="@+id/textSendTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/send_screen_title"
                android:textColor="@color/mw_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="44dp"
                android:layout_height="44dp" />
        </LinearLayout>

        <!-- Address -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/send_address_section"
            android:textColor="@color/mw_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_send_input_highlight"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="8dp">

            <EditText
                android:id="@+id/inputRecipientAddress"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:ellipsize="middle"
                android:hint="@string/send_address_hint_modern"
                android:inputType="textUri"
                android:maxLines="1"
                android:singleLine="true"
                android:textColor="@color/mw_text_primary"
                android:textColorHint="@color/mw_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/buttonPasteAddress"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:text="@string/send_paste_action"
                android:textColor="@color/mw_highlight"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/buttonScanQr"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_pill_accent"
                android:contentDescription="@string/scan_qr_action"
                android:padding="10dp"
                android:src="@drawable/ic_scan_24"
                android:tint="@color/black" />
        </LinearLayout>

        <!-- Destination network -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/send_destination_network"
            android:textColor="@color/mw_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_network_chip"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:id="@+id/imageDestinationNetworkIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_token_eth_real" />

            <TextView
                android:id="@+id/textDestinationNetwork"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/network_sepolia"
                android:textColor="@color/mw_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Amount -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/send_amount_section"
            android:textColor="@color/mw_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_send_amount_box"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp">

            <EditText
                android:id="@+id/inputEthAmount"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/send_amount_hint_modern"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:textColor="@color/mw_text_primary"
                android:textColorHint="@color/mw_text_tertiary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textAmountSymbol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/receive_asset_symbol"
                android:textColor="@color/mw_text_secondary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonMaxAmount"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_pill_highlight_ghost"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/send_max_action"
                android:textColor="@color/mw_highlight"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/inputFiatAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/amount_fiat_hint"
            android:textColor="@color/mw_text_secondary"
            android:textSize="13sp" />

        <!-- Gas fee card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_surface"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/gas_fee_title"
                android:textColor="@color/mw_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textGasFee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/gas_fee_value"
                android:textColor="@color/mw_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/send_disclaimer"
            android:textColor="@color/mw_text_tertiary"
            android:textSize="11sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonConfirmSend"
            style="@style/Widget.MatsWallet.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="22dp"
            android:text="@string/send_next_action"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/mw_highlight" />
    </LinearLayout>
</ScrollView>
