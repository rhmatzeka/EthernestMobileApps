<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/receiveRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_pin_key_action"
                android:contentDescription="@string/back_action"
                android:padding="10dp"
                android:src="@drawable/ic_back_24" />

            <TextView
                android:id="@+id/textReceiveTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/receive_screen_title"
                android:textColor="@color/mw_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/buttonInfo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_pin_key_action"
                android:contentDescription="@string/receive_screen_title"
                android:padding="10dp"
                android:src="@drawable/ic_info_24" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_receive_warning"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_receive_asset_badge"
                android:gravity="center"
                android:text="!"
                android:textColor="@color/mw_warning"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textReceiveWarning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="@string/receive_screen_subtitle"
                android:textColor="@color/mw_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageReceiveAssetIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_token_eth_real" />

            <TextView
                android:id="@+id/textReceiveAssetSymbol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/receive_asset_symbol"
                android:textColor="@color/mw_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_receive_asset_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="@string/receive_coin_badge"
                android:textColor="@color/mw_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="242dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_receive_qr_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <ImageView
                android:id="@+id/imageReceiveQr"
                android:layout_width="196dp"
                android:layout_height="196dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/qr_action"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/textReceiveQrAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="middle"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="#4B5563"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textReceiveAmountSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/receive_amount_not_set"
            android:textColor="@color/mw_text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/buttonCopy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_receive_action"
                    android:padding="17dp"
                    android:src="@drawable/ic_copy_24" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/copy_action"
                    android:textColor="@color/mw_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonSetAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_receive_action"
                    android:padding="17dp"
                    android:src="@drawable/ic_hash_24" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:gravity="center"
                    android:text="@string/receive_set_amount"
                    android:textColor="@color/mw_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonShare"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_receive_action"
                    android:padding="17dp"
                    android:src="@drawable/ic_share_24" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/share_action"
                    android:textColor="@color/mw_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/buttonDepositExchange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_surface"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_receive_deposit_icon"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_down_24" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/receive_deposit_title"
                    android:textColor="@color/mw_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/receive_deposit_subtitle"
                    android:textColor="@color/mw_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/textReceiveAddress"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:alpha="0"
            android:text="@string/wallet_address_full" />
    </LinearLayout>
</ScrollView>
